# ============================================================
# Automation Hub - Production Environment Variables
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to version control.
# ============================================================

# Application
APP_ENV=production
SECRET_KEY=your-strong-secret-key-here
FERNET_KEY=your-fernet-key-here-generate-with-python-cryptography

# Database
DATABASE_URL=sqlite+aiosqlite:////app/data/automation_hub.db

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...

# AWS / S3
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET=quantoria-static
AWS_REGION=us-east-1

# Meta Graph API
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# n8n
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-admin-password

# NextAuth (frontend)
NEXTAUTH_URL=https://hub.quantorialabs.com
NEXTAUTH_SECRET=your-strong-nextauth-secret

# API URL (frontend — points to backend)
NEXT_PUBLIC_API_URL=https://api.quantorialabs.com
